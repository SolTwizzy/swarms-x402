# SwarmX Platform Configuration
# ──────────────────────────────

# Wallet keys for x402 payments (set at least one)
# Solana private key (base58) — for Solana-network x402 payments
SOLANA_PRIVATE_KEY=
# EVM private key (hex) — for Base/Polygon/Arbitrum/Optimism x402 payments
EVM_PRIVATE_KEY=

# Default network (base-mainnet, base-sepolia, solana-mainnet, polygon-mainnet, arbitrum-mainnet, ethereum-mainnet)
X402_NETWORK_ID=base-sepolia

# Max auto-pay per request (USD). Requests above this are rejected.
X402_MAX_AUTO_PAY_USD=0.10

# Total session budget (USD). When exhausted, all payments stop.
X402_BUDGET_USD=10.00

# Your wallet address to receive payments when exposing services
X402_RECEIVE_ADDRESS=

# Access Pass — pay once for time-limited unlimited access (optional)
# Eliminates per-call x402 latency for high-frequency data/trading endpoints.
# Tiers: 24h ($1/day), 7d ($5/week), 30d ($25/month)
# For sellers: configures which pass tiers your server advertises
# For buyers: configures which pass tier to auto-purchase when available
# X402_ACCESS_PASS_TIER=24h
# X402_ACCESS_PASS_MAX_SPEND=25.00

# Dexter facilitator URL (default: https://x402.dexter.cash)
# X402_FACILITATOR_URL=

# Helius API key (free tier — for Solana wallet analyzer endpoint)
HELIUS_API_KEY=

# Swarms API key (optional, for cloud-hosted swarms)
SWARMS_API_KEY=

# Itachi Debug Bot (Telegram error alerts — optional)
# ITACHI_DEBUG_BOT_TOKEN=
# ITACHI_DEBUG_CHAT_ID=

# ElizaOS model provider — set at least one
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
