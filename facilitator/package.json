{
  "name": "swarmx-rh-facilitator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted x402 facilitator for Robinhood Chain (eip155:4663) settling USDG via EIP-3009. Standalone; not part of the main SwarmX build.",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
