    "check:domain": "bun run scripts/check-domain.ts",
    "check:chain": "bun run scripts/check-chain.ts"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  }
}
