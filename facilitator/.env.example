# swarmx-rh-facilitator — environment
# Copy to .env and adjust. NEVER commit a real private key.

# --- RPC / server ---
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com
PORT=4021

# --- sell-side ---
# Address that receives USDG payments (defaults to our EVM wallet).
X402_RECEIVE_ADDRESS=0xD421e2Cb3dF59F25AB1574E271a8b291665Ba439

# --- USDG EIP-712 domain (confirmed on-chain; override only if the token upgrades) ---
USDG_EIP712_NAME=Global Dollar
USDG_EIP712_VERSION=1

# --- DRY-RUN switch ---
# When true, /verify validates signature + fields only (no RPC, no funds).
# Used by the dry-run test. Leave unset/false in production.
# FACILITATOR_SKIP_ONCHAIN=false

# --- SETTLEMENT GATE (money) ---
# /settle NEVER broadcasts unless this is exactly "true" AND the signer is funded.
# Leave unset to keep settlement disabled.
# FACILITATOR_SETTLE_ENABLED=false

# Settlement signer. Only read when FACILITATOR_SETTLE_ENABLED=true.
# This key's ETH pays gas and it submits the USDG transferWithAuthorization tx.
# EVM_PRIVATE_KEY=0x...
